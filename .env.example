# Luma API (lu.ma -> Settings -> API -> Generate Key)
LUMA_API_KEY=

# Luma Calendar API ID (from calendar URL or settings)
LUMA_CALENDAR_API_ID=

# Shared secret for webhook URL authentication (any random string)
LUMA_WEBHOOK_SECRET=

# Flodesk API Key (flodesk.com -> Account -> Integrations -> API)
FLODESK_API_KEY=

# Upstash Redis (upstash.com -> Create Database -> REST API credentials)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin password for /admin UI
ADMIN_PASSWORD=
